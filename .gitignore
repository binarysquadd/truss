# Deploy — secrets files are committed AFTER sops encryption.
# *.dec files are local decrypted working copies — never commit these.
deploy/k8s/secrets/*.dec
deploy/secrets/*.dec
deploy/terraform/cloudflare/terraform.tfvars
deploy/terraform/cloudflare/terraform.tfstate
deploy/terraform/cloudflare/terraform.tfstate.backup
deploy/terraform/cloudflare/.terraform/
# .terraform.lock.hcl is intentionally committed — locks provider versions for reproducible CI
