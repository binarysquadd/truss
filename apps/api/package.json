{
  "name": "@truss/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "scripts": {
    "dev": "node --watch --import ./src/otel.js src/index.js",
    "start": "node --import ./src/otel.js src/index.js",
    "build:docker": "esbuild src/index.js --bundle --packages=external --platform=node --format=esm --minify --outfile=dist/index.mjs",
    "migrate:create": "node-pg-migrate create --migrations-dir db/migrations",
    "migrate:up": "node-pg-migrate --migrations-dir db/migrations up",
    "migrate:down": "node-pg-migrate --migrations-dir db/migrations down",
    "migrate:redo": "node-pg-migrate --migrations-dir db/migrations redo",
    "test": "node --test tests/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:auth": "node --test tests/auth.test.js",
    "test:health": "node --test tests/health.test.js",
    "test:demo": "node --test tests/demo.test.js",
    "test:sql": "node --test tests/sql.test.js",
    "test:modules": "node --test tests/modules.test.js",
    "test:security": "node --test tests/security.test.js",
    "test:crud": "node --test tests/crud.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-prometheus": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "cors": "^2.8.6",
    "disposable-email-domains": "^1.0.62",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  }
}
