DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
API_PORT=8787
QUERY_TIMEOUT_MS=10000
SQL_MAX_ROWS=200
KRATOS_PUBLIC_URL=http://localhost:4433
KRATOS_ADMIN_URL=http://localhost:4434
KRATOS_IDENTITY_SCHEMA_ID=default
KRATOS_ADMIN_TOKEN=
# Optional comma-separated social provider ids (e.g. google,github)
KRATOS_OIDC_PROVIDERS=
KETO_READ_URL=http://localhost:4466
KETO_WRITE_URL=http://localhost:4467
KETO_ADMIN_TOKEN=
HYDRA_PUBLIC_URL=http://localhost:4444
HYDRA_ADMIN_URL=http://localhost:4445
HYDRA_ADMIN_TOKEN=
OATHKEEPER_PROXY_URL=http://localhost:4455
OATHKEEPER_ADMIN_URL=http://localhost:4456
OATHKEEPER_ADMIN_TOKEN=
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_S3_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_FORCE_PATH_STYLE=true
# Feature Flags (flagd)
# FLAGD_HOST=localhost                    # flagd hostname (default: localhost for self-hosted)
# FLAGD_PORT=8013                         # flagd evaluation port
# FLAGD_URL=http://localhost:8013         # Full flagd URL (overrides HOST+PORT)
# Dashboard Authentication
TRUSS_AUTH_REQUIRED=false
TRUSS_ADMIN_IDENTITY_IDS=
# Demo mode: anonymous read-only access for public demos (rate-limited, no mutations)
TRUSS_DEMO_MODE=false
# Cross-origin: comma-separated frontend origins (e.g. https://truss.pages.dev,https://truss.yourdomain.com)
CORS_ALLOWED_ORIGINS=
